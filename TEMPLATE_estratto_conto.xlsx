<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Accedi — Riconciliazione Contabile</title>
<link rel="stylesheet" href="/static/css/style.css">
</head>
<body class="auth-page">
<div class="auth-card">
  <div class="auth-logo">
    <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
      <rect width="36" height="36" rx="8" fill="#1F3A5F"/>
      <path d="M10 24L14 12L18 20L22 15L26 24" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    <span>Riconciliazione Contabile</span>
  </div>
  <h1>Accedi</h1>
  {% if error %}
  <div class="alert alert-error">{{ error }}</div>
  {% endif %}
  <form method="post" action="/login">
    <div class="field">
      <label for="username">Utente</label>
      <input type="text" id="username" name="username" placeholder="operatore / revisore" required autofocus>
    </div>
    <div class="field">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" placeholder="••••••••" required>
    </div>
    <button type="submit" class="btn btn-primary btn-full">Accedi</button>
  </form>
</div>
</body>
</html>
