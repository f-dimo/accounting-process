<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Nuova riconciliazione</title>
<link rel="stylesheet" href="/static/css/style.css">
</head>
<body>
<nav class="navbar">
  <div class="nav-brand">
    <a href="/" class="nav-back">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
    </a>
    <svg width="24" height="24" viewBox="0 0 36 36" fill="none">
      <rect width="36" height="36" rx="8" fill="#1F3A5F"/>
      <path d="M10 24L14 12L18 20L22 15L26 24" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
    Nuova riconciliazione
  </div>
  <div class="nav-right">
    <span class="badge-role badge-operatore">operatore</span>
    <a href="/logout" class="btn btn-ghost btn-sm">Esci</a>
  </div>
</nav>

<main class="container container-narrow">
  <form method="post" action="/elabora" enctype="multipart/form-data" id="form">

    <section class="form-section">
      <h2>Periodo e note</h2>
      <div class="grid-2">
        <div class="field">
          <label for="periodo">Periodo di riferimento</label>
          <input type="text" id="periodo" name="periodo" placeholder="es. Luglio 2025">
        </div>
        <div class="field">
          <label for="note">Note interne</label>
          <input type="text" id="note" name="note" placeholder="opzionale">
        </div>
      </div>
    </section>

    <section class="form-section">
      <h2>File da elaborare</h2>

      <div class="upload-group">
        <label class="upload-label required">Estratto conto bancario <span class="req">*</span></label>
        <div class="upload-zone" id="zone-estratto" onclick="document.getElementById('f-estratto').click()">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity=".5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 12l2 2 4-4"/></svg>
          <span id="label-estratto">Clicca per selezionare — PDF, Excel o CSV</span>
        </div>
        <input type="file" id="f-estratto" name="estratto" accept=".pdf,.xlsx,.xls,.csv" required onchange="showFile(this,'label-estratto','zone-estratto')">
      </div>

      <div class="grid-2">
        <div class="upload-group">
          <label class="upload-label">Partitario fornitori</label>
          <div class="upload-zone upload-zone-sm" onclick="document.getElementById('f-fornitori').click()">
            <span id="label-fornitori">Excel / CSV</span>
          </div>
          <input type="file" id="f-fornitori" name="fornitori" accept=".xlsx,.xls,.csv" onchange="showFile(this,'label-fornitori','zone-fornitori')">
        </div>
        <div class="upload-group">
          <label class="upload-label">Partitario clienti</label>
          <div class="upload-zone upload-zone-sm" onclick="document.getElementById('f-clienti').click()">
            <span id="label-clienti">Excel / CSV</span>
          </div>
          <input type="file" id="f-clienti" name="clienti" accept=".xlsx,.xls,.csv" onchange="showFile(this,'label-clienti','zone-clienti')">
        </div>
        <div class="upload-group">
          <label class="upload-label">Fatture emesse</label>
          <div class="upload-zone upload-zone-sm" onclick="document.getElementById('f-emesse').click()">
            <span id="label-emesse">Excel / CSV</span>
          </div>
          <input type="file" id="f-emesse" name="emesse" accept=".xlsx,.xls,.csv" onchange="showFile(this,'label-emesse','zone-emesse')">
        </div>
        <div class="upload-group">
          <label class="upload-label">Fatture ricevute</label>
          <div class="upload-zone upload-zone-sm" onclick="document.getElementById('f-ricevute').click()">
            <span id="label-ricevute">Excel / CSV</span>
          </div>
          <input type="file" id="f-ricevute" name="ricevute" accept=".xlsx,.xls,.csv" onchange="showFile(this,'label-ricevute','zone-ricevute')">
        </div>
      </div>

      <div class="upload-group">
        <label class="upload-label">File contestazioni</label>
        <div class="upload-zone upload-zone-sm" onclick="document.getElementById('f-contestazioni').click()">
          <span id="label-contestazioni">Excel / CSV — opzionale</span>
        </div>
        <input type="file" id="f-contestazioni" name="contestazioni" accept=".xlsx,.xls,.csv" onchange="showFile(this,'label-contestazioni','zone-contestazioni')">
      </div>
    </section>

    <section class="form-section">
      <h2>Parametri abbinamento</h2>
      <div class="grid-2">
        <div class="field">
          <label for="tol_importo">Tolleranza importo (€)</label>
          <input type="number" id="tol_importo" name="tol_importo" value="0.01" step="0.01" min="0">
          <span class="field-hint">Differenza massima accettata (es. arrotondamenti)</span>
        </div>
        <div class="field">
          <label for="tol_giorni">Tolleranza date (giorni)</label>
          <input type="number" id="tol_giorni" name="tol_giorni" value="3" min="0" max="30">
          <span class="field-hint">Scarto accettato tra data estratto e scadenza</span>
        </div>
      </div>
    </section>

    <div class="form-actions">
      <a href="/" class="btn btn-ghost">Annulla</a>
      <button type="submit" class="btn btn-primary" id="btn-submit">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="13 2 13 9 20 9"/><path d="M20 14v5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h7"/></svg>
        Avvia riconciliazione
      </button>
    </div>
  </form>
</main>

<div id="overlay" class="overlay hidden">
  <div class="spinner-card">
    <div class="spinner"></div>
    <p>Elaborazione in corso…</p>
    <p class="text-muted" style="font-size:13px">Lettura file e abbinamento partite</p>
  </div>
</div>

<script>
function showFile(input, labelId, zoneId) {
  if (input.files.length) {
    document.getElementById(labelId).textContent = input.files[0].name;
    document.getElementById(zoneId) && document.getElementById(zoneId).classList.add('upload-zone--filled');
  }
}
document.getElementById('form').addEventListener('submit', function() {
  document.getElementById('overlay').classList.remove('hidden');
  document.getElementById('btn-submit').disabled = true;
});
</script>
</body>
</html>
